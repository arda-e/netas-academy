{
  "kind": "collectionType",
  "collectionName": "courses",
  "info": {
    "singularName": "course",
    "pluralName": "courses",
    "displayName": "Course",
    "description": "Courses offered by teachers"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "summary": {
      "type": "text"
    },
    "description": {
      "type": "richtext"
    },
    "topicArea": {
      "type": "enumeration",
      "enum": [
        "siber-guvenlik",
        "yazilim-gelistirme",
        "veri-bilimi",
        "bulut-altyapi",
        "is-surecleri",
        "yapay-zeka"
      ],
      "required": true
    },
    "level": {
      "type": "enumeration",
      "enum": ["temel", "orta", "ileri"]
    },
    "targetAudience": {
      "type": "text"
    },
    "businessValue": {
      "type": "text"
    },
    "scopeSummary": {
      "type": "text"
    },
    "outcomeBullets": {
      "type": "text"
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "teacher": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::teacher.teacher",
      "inversedBy": "courses"
    },
    "events": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::event.event",
      "mappedBy": "course"
    },
    "courseApplications": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::course-application.course-application",
      "mappedBy": "course"
    }
  }
}
