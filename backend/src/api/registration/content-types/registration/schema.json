{
  "kind": "collectionType",
  "collectionName": "registrations",
  "info": {
    "singularName": "registration",
    "pluralName": "registrations",
    "displayName": "Registration",
    "description": "Student registrations for events"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "status": {
      "type": "enumeration",
      "enum": ["pending", "confirmed", "cancelled", "waitlisted", "attended"],
      "default": "pending",
      "required": true
    },
    "notes": {
      "type": "text"
    },
    "lastEmailSentAt": {
      "type": "datetime"
    },
    "student": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::student.student",
      "inversedBy": "registrations",
      "required": true
    },
    "event": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::event.event",
      "inversedBy": "registrations",
      "required": true
    }
  }
}
