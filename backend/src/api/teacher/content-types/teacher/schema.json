{
  "kind": "collectionType",
  "collectionName": "teachers",
  "info": {
    "singularName": "teacher",
    "pluralName": "teachers",
    "displayName": "Teacher",
    "description": "Teacher profiles and their courses"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "fullName": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "fullName",
      "required": true
    },
    "headline": {
      "type": "string"
    },
    "bio": {
      "type": "richtext"
    },
    "email": {
      "type": "email"
    },
    "expertiseAreas": {
      "type": "json"
    },
    "targetTeams": {
      "type": "text"
    },
    "teachingApproach": {
      "type": "text"
    },
    "profilePhoto": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "courses": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::course.course",
      "mappedBy": "teacher"
    }
  }
}
