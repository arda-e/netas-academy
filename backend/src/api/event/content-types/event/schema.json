{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event",
    "description": "Course events and sessions"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "summary": {
      "type": "text"
    },
    "details": {
      "type": "richtext"
    },
    "startsAt": {
      "type": "datetime",
      "required": true
    },
    "eventType": {
      "type": "enumeration",
      "enum": ["etkinlik", "egitim", "kurs"],
      "default": "etkinlik",
      "required": true
    },
    "endsAt": {
      "type": "datetime"
    },
    "keepRegistrationsOpen": {
      "type": "boolean",
      "default": false,
      "description": "Açık olduğunda etkinliğin kayıtları, startsAt'ten 24 saat önce otomatik kapanmaz."
    },
    "location": {
      "type": "string"
    },
    "topicArea": {
      "type": "enumeration",
      "enum": [
        "siber-guvenlik",
        "yazilim-gelistirme",
        "veri-bilimi",
        "bulut-altyapi",
        "is-surecleri",
        "yapay-zeka"
      ]
    },
    "course": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course.course",
      "inversedBy": "events"
    },
    "registrations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::registration.registration",
      "mappedBy": "event"
    }
  }
}
