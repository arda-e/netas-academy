{
  "kind": "collectionType",
  "collectionName": "contact_submissions",
  "info": {
    "singularName": "contact-submission",
    "pluralName": "contact-submissions",
    "displayName": "Contact Submission",
    "description": "Contact form submissions captured from the academy site"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "leadType": {
      "type": "enumeration",
      "enum": [
        "corporate_training_request",
        "instructor_application",
        "solution_partner_application",
        "general_contact"
      ],
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["new", "contacted", "closed"],
      "default": "new",
      "required": true
    },
    "fullName": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "company": {
      "type": "string"
    },
    "message": {
      "type": "text",
      "required": true
    },
    "interestTopic": {
      "type": "string",
      "description": "Training or topic of interest for corporate training requests"
    },
    "expertiseAreas": {
      "type": "text",
      "description": "Areas of expertise for instructor applications"
    },
    "companySize": {
      "type": "string",
      "description": "Company size for solution partner applications"
    },
    "partnershipDetails": {
      "type": "text",
      "description": "Partnership motivation and details for solution partner applications"
    },
    "submittedAt": {
      "type": "datetime",
      "required": true
    }
  }
}
